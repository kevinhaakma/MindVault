#!/usr/bin/env python3
"""mindvault-secret — manage secrets in the OS keychain.

Vex keeps keys here, not in memory. This is the CLI for the vault door.

Usage:
  mindvault-secret set <name>    prompt for value, store in keychain
  mindvault-secret get <name>    print value (manual debugging only)
  mindvault-secret rm  <name>    remove from keychain
  mindvault-secret list          list stored names
"""
import getpass
import json
import os
import sys

try:
    import keyring
except ImportError:
    print("keyring not installed. Run: pip install keyring", file=sys.stderr)
    sys.exit(1)

SERVICE = "mindvault"
INDEX   = os.path.expanduser("~/.mindvault/secret_index.json")


def _load_index() -> list[str]:
    try:
        with open(INDEX) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return []


def _save_index(names: list[str]):
    os.makedirs(os.path.dirname(INDEX), exist_ok=True)
    with open(INDEX, "w") as f:
        json.dump(sorted(set(names)), f)


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "set":
        if len(sys.argv) < 3:
            print("Usage: mindvault-secret set <name>", file=sys.stderr)
            sys.exit(1)
        name = sys.argv[2]
        val  = getpass.getpass(f"{name}: ")
        keyring.set_password(SERVICE, name, val)
        names = _load_index()
        if name not in names:
            names.append(name)
        _save_index(names)
        print(f"stored '{name}' in keychain")

    elif cmd == "get":
        if len(sys.argv) < 3:
            print("Usage: mindvault-secret get <name>", file=sys.stderr)
            sys.exit(1)
        val = keyring.get_password(SERVICE, sys.argv[2])
        print(val or "(not found)")

    elif cmd == "rm":
        if len(sys.argv) < 3:
            print("Usage: mindvault-secret rm <name>", file=sys.stderr)
            sys.exit(1)
        name = sys.argv[2]
        try:
            keyring.delete_password(SERVICE, name)
        except keyring.errors.PasswordDeleteError:
            print(f"'{name}' not found in keychain", file=sys.stderr)
            sys.exit(1)
        names = _load_index()
        _save_index([n for n in names if n != name])
        print(f"removed '{name}'")

    elif cmd == "list":
        names = _load_index()
        if not names:
            print("(no secrets stored)")
        else:
            for n in names:
                print(n)

    else:
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
